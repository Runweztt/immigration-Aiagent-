# LoopedAI Bot Configuration
# Copy this to .env and fill in the values

# Your Telegram BotFather token for @loopedaibot
TELEGRAM_BOT_TOKEN=your-botfather-token-here

# Immigration AI Agent API URL (OpenClaw or direct)
IMMIGRATION_API_URL=http://localhost:8000/immigration-advice/

# Path to SQLite database file  
LOOPEDAI_DB_PATH=/opt/loopedai-bot/loopedai.db
